# ================================================
# 店播AI Agent - 生产环境配置
# 复制此文件为 .env，然后填写实际值
# ================================================

# ================================================
# 必选配置
# ================================================

# 通义千问 API Key (必需，用于脚本生成)
# 获取地址：https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-your-api-key-here

# Supabase 项目 URL
# 获取地址：https://supabase.com/dashboard/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ================================================
# 可选配置
# ================================================

# 抖音热点 API Key（可选，不配置则使用内置 mock 数据）
# 获取地址：https://xxapi.cn
DOUYIN_HOT_API_KEY=a3e1f9175744cfa4

# 服务器端口（默认 3000）
PORT=3000

# ================================================
# 高级配置（通常不需要修改）
# ================================================

NODE_ENV=production
TZ=Asia/Shanghai